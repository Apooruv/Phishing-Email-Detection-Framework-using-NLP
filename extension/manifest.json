{
  "manifest_version": 3,
  "name": "PhishGuard Extension",
  "version": "1.0",
  "description": "Extracts email data from Gmail for phishing analysis.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://mail.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}
